{
  "id": "sesler-ve-heceler",
  "baslik": "Sesler ve Heceler",
  "kazanimKodu": "TUR.2.1.1",
  "anlatim": {
    "ekranlar": [
      {
        "metin": "Türkçede 29 harf vardır. 8 tanesi sesli (a, e, ı, i, o, ö, u, ü), 21 tanesi sessiz harftir. Sesli harfler tek başına ses çıkarır!",
        "gorsel": {
          "tur": "turkce",
          "mod": "anlatim",
          "sahne": "sh-anlatim-1"
        }
      },
      {
        "metin": "Hece, içinde en az bir sesli harf bulunan ses topluluğudur. \"araba\" kelimesi 3 heceli: a-ra-ba. Her hecede bir sesli harf vardır!",
        "gorsel": {
          "tur": "turkce",
          "mod": "anlatim",
          "sahne": "sh-anlatim-2"
        }
      },
      {
        "metin": "Kelimeyi hecelere bölerken sesli harfleri sayarız — kaç sesli harf varsa o kadar hece vardır! \"okul\" → o-kul (2 sesli = 2 hece).",
        "gorsel": {
          "tur": "turkce",
          "mod": "anlatim",
          "sahne": "sh-anlatim-3"
        }
      }
    ]
  },
