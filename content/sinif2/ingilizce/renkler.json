{
  "id": "renkler",
  "baslik": "Colors",
  "kazanimKodu": "ING.2.4.1",
  "anlatim": {
    "ekranlar": [
      {
        "metin": "Berk elinde rengarenk bir boya kutusuyla okula geldi. Kırmızı Red, mavi Blue, sarı Yellow, yeşil Green, turuncu Orange ve pembe Pink! Sınıfları İngilizce renklerle açan harika bir gökkuşağına dönüştü.",
        "gorsel": {
          "tur": "ingilizce",
          "mod": "anlatim",
          "sahne": "rk-anlatim-1"
        }
      },
      {
        "metin": "Ali, Ayşe ve Berk öğrendikleri renkleri birleştirerek oyun oynadılar. \"Red apple!\", \"Blue sky!\", \"Yellow sun!\" Siyah Black, beyaz White ve mor Purple renkleri de oyunlarına kattılar.",
        "gorsel": {
          "tur": "ingilizce",
          "mod": "anlatim",
          "sahne": "rk-anlatim-2"
        }
      },
      {
        "metin": "Öğretmenleri tahtaya bir gökkuşağı çizdi. \"Colors are beautiful!\" dedi. Çocuklar renkleri İngilizce söyleyerek sınıfı renkli bir dünyaya çevirdiler.",
        "gorsel": {
          "tur": "ingilizce",
          "mod": "anlatim",
          "sahne": "rk-anlatim-3"
        }
      }
    ]
  },
