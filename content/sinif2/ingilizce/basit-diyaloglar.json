  "kazanimKodu": "ING.2.4.2",
  "anlatim": {
    "ekranlar": [
      {
        "metin": "Selin ve Yusuf parkta karşılaştılar. Selin: \"Hello Yusuf! How are you?\" (Nasılsın?). Yusuf: \"I am fine, thank you. And you?\" (Ben iyiyim, ya sen?). Selin: \"I am good, let's play!\" (İyiyim, hadi oynayalım!).",
        "gorsel": {
          "tur": "ingilizce",
          "mod": "anlatim",
          "sahne": "bd-anlatim-1"
        }
      },
      {
        "metin": "Mehmet: \"Can I have an apple, please?\" (Bir elma alabilir miyim?). Bakkal: \"Here you are!\" (Buyurun!). Mehmet: \"Thank you!\" (Teşekkür ederim).",
        "gorsel": {
          "tur": "ingilizce",
          "mod": "anlatim",
          "sahne": "bd-anlatim-2"
        }
      },
      {
        "metin": "Ali: \"May I come in?\" (İçeri girebilir miyim?). Öğretmen: \"Yes, you may.\" (Evet). Öğretmen: \"Stand up!\" (Ayağa kalk). Öğretmen: \"Sit down!\" (Otur).",
        "gorsel": {
          "tur": "ingilizce",
          "mod": "anlatim",
          "sahne": "bd-anlatim-3"
        }
      }
    ]
  },
