{
  "id": "kisa-hikayeler",
  "baslik": "Short Stories",
  "kazanimKodu": "ING.2.4.1",
  "anlatim": {
    "ekranlar": [
      {
        "metin": "Ali ve Ayşe kütüphanede \"The Little Red Apple\" hikayesini okudular. Yeşil ağacın dalındaki mutlu kırmızı elma güneşe gülümsüyordu. \"Read a story\" İngilizce yeni kelimeler öğrenmek için çok eğlenceliydi!",
        "gorsel": {
          "tur": "ingilizce",
          "mod": "anlatim",
          "sahne": "kh-anlatim-1"
        }
      },
      {
        "metin": "Berk ve Fatma \"The Brave Dog\" hikayesini okudular. Köpek koyunları (Sheep) koruyordu — gerçekten çok cesur (Brave)! Dog, Run, Jump kelimelerini öğrendiler.",
        "gorsel": {
          "tur": "ingilizce",
          "mod": "anlatim",
          "sahne": "kh-anlatim-2"
        }
      },
      {
        "metin": "Can ve Zeynep \"The Happy Bird\" kitabını seçtiler. Kuş sabahları \"Good morning!\" diyor ve gökyüzünde özgürce uçuyordu (Fly). Sing a song yapıyor, ormandaki Animals dinliyordu.",
        "gorsel": {
          "tur": "ingilizce",
          "mod": "anlatim",
          "sahne": "kh-anlatim-3"
        }
      }
    ]
  },
