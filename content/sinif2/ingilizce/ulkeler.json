    "ekranlar": [
      {
        "metin": "Elanaz ve Berk sınıfta dünya haritasına baktılar. Türkiye Turkey, İngiltere England! Her ülkenin bayrağı farklı ve güzeldi.",
        "gorsel": {
          "tur": "ingilizce",
          "mod": "anlatim",
          "sahne": "ul-anlatim-1"
        }
      },
      {
        "metin": "Öğretmen Fransa France, Almanya Germany ve İspanya Spain ülkelerini gösterdi. \"Country\" kelimesi ülke demektir. Haritada yeni yerler keşfetmek çok heyecanlıydı!",
        "gorsel": {
          "tur": "ingilizce",
          "mod": "anlatim",
          "sahne": "ul-anlatim-2"
        }
      },
      {
        "metin": "Japonya Japan, Çin China ve Mısır Egypt haritada uzak ülkelerdi. Elanaz \"I love my country Turkey!\" dedi. Ülkeleri İngilizce öğrenmek dünyayı tanımak gibiydi.",
        "gorsel": {
          "tur": "ingilizce",
          "mod": "anlatim",
          "sahne": "ul-anlatim-3"
        }
      }
    ]
  },
