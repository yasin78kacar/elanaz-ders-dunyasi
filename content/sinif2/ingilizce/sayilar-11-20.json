{
  "id": "sayilar-11-20",
  "baslik": "Numbers 11-20",
  "kazanimKodu": "ING.2.9.4",
  "anlatim": {
    "ekranlar": [
      {
        "metin": "Sınıfta sayıları öğreniyorlardı. \"Eleven, twelve, thirteen!\" diye saydılar. 11'den 20'ye kadar her sayının İngilizce adı vardı.",
        "gorsel": {
          "tur": "ingilizce",
          "mod": "anlatim",
          "sahne": "sy-anlatim-1"
        }
      },
      {
        "metin": "Tahtada sayılar yazılıydı. \"Fourteen, fifteen, sixteen!\" Berk de saydı. Saymak İngilizcede de eğlenceliydi.",
        "gorsel": {
          "tur": "ingilizce",
          "mod": "anlatim",
          "sahne": "sy-anlatim-2"
        }
      },
      {
        "metin": "17, 18, 19, 20! Son sayıya ulaştılar. \"We can count to twenty in English!\" dediler. Sayılar her yerdeydi.",
        "gorsel": {
          "tur": "ingilizce",
          "mod": "anlatim",
          "sahne": "sy-anlatim-3"
        }
      }
    ]
  },
