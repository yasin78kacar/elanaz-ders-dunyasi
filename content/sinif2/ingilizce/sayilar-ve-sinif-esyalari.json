{
  "id": "sayilar-ve-sinif-esyalari",
  "baslik": "Numbers and Classroom",
  "kazanimKodu": "ING.2.1.2",
  "anlatim": {
    "ekranlar": [
      {
        "metin": "Zeynep ve Can okula çok enerjik geldiler. Öğretmenleri tahtaya kocaman sayılar çizmişti: \"One, two, three, four, five! Six, seven, eight, nine, ten!\" İngilizce sayı saymak çok eğlenceli bir tekerleme gibiydi.",
        "gorsel": {
          "tur": "ingilizce",
          "mod": "anlatim",
          "sahne": "se-anlatim-1"
        }
      },
      {
        "metin": "Hande çantasını sırasının üzerine koydu. Tahta Board, çanta Bag, kalem Pen, kurşun kalem Pencil, kitap Book, masa Desk, sandalye Chair! Sınıf artık İngilizce kelimelerle dolu bir hazine sandığıydı.",
        "gorsel": {
          "tur": "ingilizce",
          "mod": "anlatim",
          "sahne": "se-anlatim-2"
        }
      },
      {
        "metin": "Öğretmen masanın üzerine üç kitap koydu: \"How many books? Three books!\" Can'ın iki kurşun kalemi: \"Two pencils!\" Hande sırasını gösterdi: \"One desk!\" Rakamlar ve eşyalar yan yana gelince her şey daha anlamlı oldu.",
        "gorsel": {
          "tur": "ingilizce",
          "mod": "anlatim",
          "sahne": "se-anlatim-3"
        }
      }
    ]
  },
