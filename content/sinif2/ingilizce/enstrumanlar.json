          "tur": "ingilizce",
          "mod": "anlatim",
          "sahne": "en-anlatim-1"
        }
      },
      {
        "metin": "Davula vurdular: \"Drum!\" Flüt üflediler: \"Flute!\" Trompet sesi sınıfı doldurdu. Her enstrüman farklı ve güzel bir ses çıkarıyordu.",
        "gorsel": {
          "tur": "ingilizce",
          "mod": "anlatim",
          "sahne": "en-anlatim-2"
        }
      },
      {
        "metin": "Orkestra konserinde birçok instrument bir arada çaldı. \"Play the piano, play the guitar!\" İngilizce enstrüman adları müziği daha da renkli yapıyordu.",
        "gorsel": {
          "tur": "ingilizce",
          "mod": "anlatim",
          "sahne": "en-anlatim-3"
        }
      }
    ]
  },
