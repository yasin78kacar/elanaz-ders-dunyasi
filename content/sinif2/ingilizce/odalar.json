    "ekranlar": [
      {
        "metin": "Elanaz evini tanıttı. \"This is my bedroom. This is the kitchen.\" Her odanın bir adı vardı. Ev çok sıcaktı.",
        "gorsel": {
          "tur": "ingilizce",
          "mod": "anlatim",
          "sahne": "od-anlatim-1"
        }
      },
      {
        "metin": "Banyoda dişlerini fırçaladı. Oturma odasında ailesiyle TV izledi. \"I love my house!\" dedi.",
        "gorsel": {
          "tur": "ingilizce",
          "mod": "anlatim",
          "sahne": "od-anlatim-2"
        }
      },
      {
        "metin": "Bahçede oynadılar. \"The garden is beautiful!\" dedi Berk. Evin her odası farklıydı ve hepsi güzeldi.",
        "gorsel": {
          "tur": "ingilizce",
          "mod": "anlatim",
          "sahne": "od-anlatim-3"
        }
      }
    ]
  },
