          "tur": "islem",
          "mod": "anlatim",
          "sahne": "bl-anlatim-2"
        }
      },
      {
        "metin": "Bölme, çarpmanın tersidir. 3 × 4 = 12 ise 12 ÷ 3 = 4 ve 12 ÷ 4 = 3 olur.",
        "gorsel": {
          "tur": "islem",
