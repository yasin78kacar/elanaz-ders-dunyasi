  "anlatim": {
    "ekranlar": [
      {
        "metin": "Elanaz Görsel Sanatlar dersinde baskı sanatları konusunu öğrendi. Renkler, formlar ve sanat teknikleri bir araya gelince güzel eserler ortaya çıkar.",
        "gorsel": {
          "tur": "gorsel-sanatlar",
          "mod": "anlatim",
          "sahne": "malzemeler"
        }
      },
      {
        "metin": "Öğretmeni malzemeleri tanıttı ve sınıfta birlikte uygulama yaptılar. Elanaz dikkatle dinledi ve kendi çalışmasını oluşturdu.",
        "gorsel": {
          "tur": "gorsel-sanatlar",
          "mod": "anlatim",
          "sahne": "malzemeler"
        }
      },
      {
        "metin": "Ders sonunda eserlerini sergilediler. Elanaz sanatın hem eğlenceli hem öğretici olduğunu anladı.",
        "gorsel": {
          "tur": "gorsel-sanatlar",
          "mod": "anlatim",
          "sahne": "turk-sanatlari"
        }
      }
    ]
  },
